<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BatchPay.Frontend.Views.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:BatchPay.Frontend.ViewModels"
    x:DataType="vm:HomeViewModel"
    BackgroundColor="#02040A"
    Padding="0">

    <Grid RowDefinitions="*,Auto">
        <Grid Grid.RowSpan="2">
            <Image Source="sharepay_home_bg.svg"
                   Aspect="AspectFill"
                   HorizontalOptions="Fill"
                   VerticalOptions="Fill" />

            <BoxView Color="#02040A" Opacity="0.16" />
        </Grid>

        <!-- Main content -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="18,12,18,24"
                                 Spacing="18">

                <Label Text="Forside"
                       TextColor="White"
                       FontSize="17"
                       FontAttributes="Bold"
                       Margin="0,4,0,0" />

                <!-- Aktiv ordre -->
                <Border StrokeThickness="1.2"
                        BackgroundColor="#1C2030"
                        StrokeShape="RoundRectangle 26"
                        Padding="18,16">
                    <Border.Stroke>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#F0B84B" Offset="0.0" />
                            <GradientStop Color="#16D8F5" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Stroke>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnOverblikTapped" />
                    </Border.GestureRecognizers>

                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12"
                              RowDefinitions="Auto,Auto"
                              RowSpacing="2">

                            <Border Grid.RowSpan="2"
                                    WidthRequest="50"
                                    HeightRequest="50"
                                    StrokeThickness="1.2"
                                    Stroke="#F0B84B"
                                    BackgroundColor="#0B1822"
                                    StrokeShape="RoundRectangle 25"
                                    Padding="11"
                                    VerticalOptions="Center">
                                <Image Source="{Binding ActiveOrderIconSource}"
                                       WidthRequest="24"
                                       HeightRequest="24"
                                       Aspect="AspectFit"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>

                            <Label Grid.Column="1"
                                   Text="{Binding ActiveOrderTitle}"
                                   TextColor="White"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   VerticalOptions="End"
                                   LineBreakMode="TailTruncation" />

                            <Label Grid.Column="1"
                                   Grid.Row="1"
                                   Text="{Binding ActiveMerchantName}"
                                   TextColor="#B7C6D0"
                                   FontSize="13"
                                   LineBreakMode="TailTruncation" />
                        </Grid>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Deltagere"
                                   TextColor="#8EA3AF"
                                   FontSize="12" />

                            <HorizontalStackLayout Spacing="0"
                                                   BindableLayout.ItemsSource="{Binding ActiveParticipants}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:HomeParticipantChipVm">
                                        <Grid WidthRequest="36"
                                              HeightRequest="36"
                                              Margin="0,0,-6,0">

                                            <Border WidthRequest="32"
                                                    HeightRequest="32"
                                                    Background="{Binding FillColor}"
                                                    Stroke="{Binding StrokeColor}"
                                                    StrokeThickness="1.1"
                                                    StrokeShape="RoundRectangle 16"
                                                    HorizontalOptions="Start"
                                                    VerticalOptions="Start">
                                                <Label Text="{Binding Initials}"
                                                       TextColor="White"
                                                       FontSize="10"
                                                       FontAttributes="Bold"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center" />
                                            </Border>

                                            <Border WidthRequest="14"
                                                    HeightRequest="14"
                                                    BackgroundColor="#1FBF75"
                                                    Stroke="#EAFBF2"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 7"
                                                    HorizontalOptions="End"
                                                    VerticalOptions="End"
                                                    IsVisible="{Binding HasPaid}">
                                                <Label Text="✓"
                                                       TextColor="White"
                                                       FontSize="9"
                                                       FontAttributes="Bold"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Notifikationer -->
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Notifikationer"
                               TextColor="White"
                               FontSize="19"
                               FontAttributes="Bold" />

                        <Label Grid.Column="1"
                               Text="Se alle"
                               TextColor="#8CCCF3"
                               FontSize="13"
                               VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBeskederTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <Border BackgroundColor="{Binding NotificationCardBackground}"
                            Stroke="{Binding NotificationCardStroke}"
                            StrokeThickness="{Binding NotificationCardStrokeThickness}"
                            StrokeShape="RoundRectangle 18"
                            Padding="14,12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBeskederTapped" />
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12">

                            <Grid WidthRequest="40"
                                  HeightRequest="40">
                                <Border WidthRequest="40"
                                        HeightRequest="40"
                                        BackgroundColor="#0D1A27"
                                        Stroke="#28425A"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 20">
                                    <Image Source="sharepay_messages.svg"
                                           WidthRequest="18"
                                           HeightRequest="18"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>

                                <Border WidthRequest="10"
                                        HeightRequest="10"
                                        BackgroundColor="#22C55E"
                                        Stroke="#EAFBF2"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 5"
                                        HorizontalOptions="End"
                                        VerticalOptions="Start"
                                        Margin="0,-1,-1,0"
                                        IsVisible="{Binding IsNotificationUnread}" />
                            </Grid>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2">
                                <Label Text="{Binding NotificationTitle}"
                                       TextColor="#F4F7FB"
                                       FontSize="14"
                                       FontAttributes="{Binding NotificationTitleAttributes}"
                                       LineBreakMode="TailTruncation" />
                                <Label Text="{Binding NotificationSubtitle}"
                                       TextColor="{Binding NotificationSubtitleColor}"
                                       FontSize="12"
                                       LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>

                            <Label Grid.Column="2"
                                   Text="›"
                                   TextColor="#7D94AC"
                                   FontSize="24"
                                   VerticalTextAlignment="Center" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- ekstra luft så content ikke kolliderer med test-login nederst -->
                <BoxView HeightRequest="40"
                         Opacity="0" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Test-login helt i bunden -->
        <Border Grid.Row="1"
                BackgroundColor="#050A12"
                Stroke="#162434"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 18,18,0,0"
                Padding="14,10,14,12">
            <VerticalStackLayout Spacing="8">
                <Border Stroke="#24303F"
                        StrokeThickness="1"
                        Background="#070B12"
                        StrokeShape="RoundRectangle 16"
                        Padding="10,2"
                        HeightRequest="46">
                    <Picker Title="Vælg bruger"
                            TitleColor="#8FA0B4"
                            TextColor="#EDEDED"
                            FontSize="13"
                            BackgroundColor="Transparent"
                            ItemsSource="{Binding Users}"
                            ItemDisplayBinding="{Binding DisplayName}"
                            SelectedItem="{Binding SelectedUser}" />
                </Border>

                <Border Stroke="#283344"
                        StrokeThickness="1"
                        Background="#070B12"
                        StrokeShape="RoundRectangle 18"
                        Padding="0"
                        HeightRequest="48">
                    <Button Text="Log ind"
                            HeightRequest="48"
                            CornerRadius="18"
                            BackgroundColor="Transparent"
                            TextColor="#F3F5F8"
                            FontSize="14"
                            FontAttributes="Bold"
                            Command="{Binding LoginCommand}" />
                </Border>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Padding="4,0,4,0">
                    <Label Grid.Column="0"
                           Text="Opret dig som bruger"
                           TextColor="#2FE2B5"
                           FontSize="12"
                           HorizontalTextAlignment="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSignupTapped" />
                        </Label.GestureRecognizers>
                    </Label>

                    <Label Grid.Column="1"
                           Text="Log ud"
                           TextColor="#F2A33D"
                           FontSize="12"
                           HorizontalTextAlignment="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>